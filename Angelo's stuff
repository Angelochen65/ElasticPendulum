Web VPython 3.2

#Sliders will be used to change the following variables; default values so far 
cow_mass = 5  #initial mass of cow 
spring_num = 1 #initial number of springs VARIABLE
k_rope = 500 #total spring constant VARIABLE
node_num = 1 #total number of nodes VARIABLE; 1 is default, with spring and cow 
spring_num = node_num 
rope_length = 1 #VARIABLE
rope_mass = 5 #VARIABLE 

#The following variables are calculated based on the sliders 
k_each = k_rope / spring_num #CALCULATED 
spring_length = rope_length / spring_num #CALCULATED 
gravity = vector(0,-9.81,0)
node_mass = rope_mass / node_num #CALCULATED 


attatchment_point = box(pos=vector(0, 5, 0), size=vector(2, 0.1, 0.1), color=color.gray(1))
spring0 = helix(pos=vector(0,5,0), axis=vector(0,-1,0), size=vector(5,1,1), stiffness=1.0 )
cow = sphere(pos=spring0.pos+spring0.axis, radius=0.1, color=color.white)

springList = []
springList.append(spring0)

def change_length(l):
    global rope_length, spring_length

    rope_length = l.value
    spring_length = rope_length
    cow.pos = spring0.pos + vector(0,-spring_length,0)
    cow.vel = vector(0,0,0)

rope_length_slider = slider(bind=change_length, min=0.5, max=5, step=0.1, value=rope_length)


def change_cow_mass(l):
    global cow_mass
    cow_mass = l.value

cow_mass_slider = slider(bind=change_cow_mass,min=0.5,max=20,step=0.1,value=cow_mass)


t = 0
dt = 0.001
mass_init_v = 0
cow.vel = vector(0,0,0)
cow.acc = vector(0,0,0)
elongation = vector(0,0,0)



while True: 
    rate(60)
    
    r = cow.pos-spring0.pos
    if mag(r) > 0:
       r_hat = norm(r)
    else:
        r_hat = vector(0,0,0)
    current_length = mag(r)
    elongation = current_length - spring_length 
    
    
    spring_force = - k_each * elongation * r_hat
    gravitational_force = cow_mass * gravity
    
    f_net = gravitational_force + spring_force
    cow.acc = f_net / cow_mass
    cow.vel+= cow.acc * dt
    cow.pos+= cow.vel * dt
    
    spring0.axis = cow.pos - spring0.pos
    
    
    

