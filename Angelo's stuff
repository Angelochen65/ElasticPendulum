#Sliders will be used to change the following variables; default values so far 
cow_mass = 50 #initial mass of cow 
spring_num = 1 #initial number of springs VARIABLE
k_rope = 500 #total spring constant VARIABLE
node_num = 1 #total number of nodes VARIABLE; 1 is default, with spring and cow 
rope_length = 2 #VARIABLE
rope_mass = 5 #VARIABLE 
init_longangle = pi
init_zangle = 0
springList = []
massList = []
springPos = vector(0,5,0)
springAxis = vector(0,-2,0)
scene.camera.pos = vec(0,5,5)
addSpring = False

#The following variables are calculated based on the sliders 
k_each = k_rope / node_num #CALCULATED 
spring_length = rope_length / node_num #CALCULATED 
gravity = vector(0,-9.81,0)
node_mass = rope_mass / node_num #CALCULATED 


attatchment_point = box(pos=springPos, size=vector(2, 0.1, 0.1), color=color.gray(1))
spring0 = helix(pos=vector(0,5,0), axis=springAxis, size=vector(spring_length,1,1), stiffness=1 )
axis = spring0.axis
init_cowpos = springPos + springAxis
cow = sphere(pos=springPos + springAxis, radius=0.2, color=color.white)
springList.append(spring0)


def change_nodes(num):
    global node_num
    node_num = num.value
    k_each = k_rope / node_num
    spring_length = rope_length/node_num
    node_mass = rope_mass / node_num
    NodesText.text = '{:1.2f}'.format(num.value)
    global addSpring
    addSpring = True
    
scene.append_to_caption("Change Nodes\n\n")
nodes_slider = slider(bind=change_nodes, min=1, max = 5, step = 1, value = 1)
NodesText = wtext(text='{:1.2f}'.format(nodes_slider.value))
scene.append_to_caption('\n\n')



    

def change_length(l):
    totalChange = l.value
    eachChange = totalChange / node_num
    currentPos = springPos
    for i in range(node_num):
        springList[i].pos = currentPos
        springList[i].axis = vector(0, -eachChange, 0)
        currentPos += springList[i].axis
        if i < len(massList):
            massList[i].pos = currentPos
    cow.pos= currentPos
    LengthText.text = '{:1.2f}'.format(l.value)


scene.append_to_caption("Spring Length\n\n")
rope_length_slider = slider(bind=change_length, min=spring_length, max=10, step=0.1, value=spring_length)
LengthText = wtext(text='{:1.2f}'.format(rope_length_slider.value))
scene.append_to_caption('\n\n')
   
def change_cow_mass(num):
    global cow_mass
#    cow.radius=num.value
    cow_mass= num.value
    CowText.text = '{:1.2f}'.format(num.value)
    
scene.append_to_caption("Mass of Cow\n\n")
cow_mass_slider = slider(bind=change_cow_mass, min=10, max=100, step=1, value=cow_mass)
CowText = wtext(text='{:1.2f}'.format(change_cow_mass.value))
scene.append_to_caption('\n\n')

def change_angle_long(ang):
    
    each = rope_length / node_num
    currentPos = springPos
    for i in range(node_num):
        springList[i].pos = currentPos
        springList[i].axis.x = -sin(ang.value) * each
        springList[i].axis.y = cos(ang.value) * each
        currentPos+= springList[i].axis
        
        if i < len(massList):
            massList[i].pos = currentPos
    cow.pos = currentPos
    LongAngleText.text = '{:1.2f}'.format(ang.value)

def change_angle_zaxis(ang):
    each = rope_length / node_num
    currentPos = springPos
    for i in range(node_num):
        springList[i].pos = currentPos
        springList[i].axis.z = -sin(ang.value) * each
        currentPos += springList[i].axis
        
        if i < len(massList):
            massList[i].pos = currentPos
    cow.pos = currentPos
        
        

    ZAngleText.text = '{:1.2f}'.format(ang.value)
    
    

scene.append_to_caption("XY Spring Angle\n\n")
angle_slider_long = slider(bind=change_angle_long, min=pi/2, max=3*pi/2, step=pi/30, value=init_longangle)
LongAngleText = wtext(text='{:1.2f}'.format(angle_slider_long.value))
scene.append_to_caption('\n\n')
scene.append_to_caption("Z Spring Angle\n\n")
angle_slider_zaxis = slider(bind=change_angle_zaxis, min=-pi/2, max=pi/2, step=pi/30, value=init_zangle)
ZAngleText = wtext(text='{:1.2f}'.format(angle_slider_zaxis.value))

t = 0
dt = 0.001
mass_init_v = 0
cow.vel = vector(0,0,0)
cow.acc = vector(0,0,0)
elongation = 0

running = False

startButton = button(bind=bouncing, text="Click to start", background=color.red, pos=scene.title_anchor)
resetButon = button(bind=reset, text = "Reset", background = color.blue, pos = scene.title_anchor)

ke_graph = graph(title="Kinetic Energy vs. Time", xtitle="Time (s)", ytitle="Kinetic Energy (J)", align = "left")
ke_curve = gcurve(color=color.blue, label = "Kinetic Energy")
ue_graph = graph(title="Elastic Potential Energy vs. Time", xtitle="Time (s)", ytitle="Elastic Potential Energy (J)", align = "left")
ue_curve = gcurve(color=color.red, label = "Elastic Potential Energy")
ug_graph = graph(title="Gravitational Potential Energy vs. Time", xtitle="Time (s)", ytitle="Gravitational Potential Energy (J)", align = "left")
ug_curve = gcurve(color=color.green, label = "Gravitational Potential Energy")
phase_graph = graph(title="Phase Graph", xtitle="Cow Position", ytitle="Cow Velocity", align = "left")
phase_curve = gcurve(color=color.orange, label = "Phase Graph")

ugenergy = 0

def reset():
    global running, t, cow, spring0, springList, addSpring, massList
    ke_curve.data = []
    ue_curve.data = []
    ug_curve.data = []
    phase_curve.data = []
    startButton.text = "Click to Start"
    running = False
    addSpring = False
    if node_num > 1:
        for s in springList:
            s.visible = False
        for m in massList: 
            m.visible = False
        massList = []
        springList = []
        
        currentPos = springPos
        for i in range(node_num):
            newSpring = helix(pos = currentPos, axis = eachAxis, size=vector(spring_length / node_num,1,1), stiffness = 1)
            springList.append(newSpring)
            currentPos+= eachAxis
            if( i < node_num - 1):
                newMass = sphere(pos = currentPos, radius = 0.1, color = color.white)
                newMass.vel = vector(0,0,0)
                newMass.acc = vector(0,0,0)
                massList.append(newMass)
        cow.pos = springList[-1].pos + springList[-1].axis
        spring0 = springList[0]
    else:
        spring0.pos = springPos
        spring0.axis = springAxis
        cow.pos = springPos + springAxis
    t = 0
    dt = 0.001
    mass_init_v = 0
    cow.vel = vector(0,0,0)
    cow.acc = vector(0,0,0)
    elongation = 0
    angle_slider_long.value = init_longangle
    angle_slider_zaxis.value = init_zangle
    rope_length_slider.value = spring_length
    cow_mass_slider.value = cow_mass
    scene.camera.pos = vec(0,5,5)
    wt.text=rope_length
   
    
   

def bouncing():
    global running
    
    running = not running

while True:  
    rate(1/dt)
    if not running: 
        cow_mass_slider.disabled = False
        rope_length_slider.disabled = False
        angle_slider_long.disabled = False
        angle_slider_zaxis.disabled = False
        nodes_slider.disabled = False

        startButton.text = "Start"
        if(node_num > 1 and addSpring):
            for s in springList:
                s.visible = False
            for m in massList:
                m.visible = False
            massList = []
            springList = []
            eachAxis = vector(0, - rope_length / node_num, 0)
            currentPos = springPos
            for i in range(node_num):
                
                newSpring = helix(pos = currentPos, axis = eachAxis, size=vector(spring_length / node_num,1,1), stiffness = 1)
                springList.append(newSpring)
                currentPos+= eachAxis
                if( i < node_num - 1):
                    newMass = sphere(pos = currentPos, radius = 0.1, color = color.white)
                    newMass.vel = vector(0,0,0)
                    newMass.acc = vector(0,0,0)
                    massList.append(newMass)
                
            cow.pos = springList[-1].pos + springList[-1].axis
            spring0 = springList[0]
            addSpring = not addSpring
    if running: 
        global node_mass, k_each
        cow_mass_slider.disabled = True
        rope_length_slider.disabled = True
        angle_slider_long.disabled = True
        angle_slider_zaxis.disabled = True
        nodes_slider.disabled = True
        
        ke_curve.visible = True
        startButton.text = "Stop"
        if len(massList) > 0:
            springList[0].pos = springPos
            springList[0].axis = massList[0].pos - springPos
            
            for i in range(1, len(massList)):
                springList[i].pos = massList[i-1].pos
                springList[i].axis = massList[i].pos - massList[i-1].pos
            
            springList[-1].pos = massList[-1].pos
            springList[-1].axis = cow.pos - massList[-1].pos
            
            forces = []
            
            for i in range(len(massList)):
                m = massList[i]
                
                if i ==0:
                    above = springPos
                else:
                    above = massList[i-1].pos
                
                r_top = above - m.pos
                F_top = k_each * (mag(r_top) - spring_length/node_num) * norm(r_top)
                
                if i < len(massList) - 1:
                    below = massList[i+1].pos
                else:
                    below = cow.pos
                r_below = below - m.pos
                F_below = k_each * (mag(r_below) - spring_length/node_num) * norm(r_below)
                
                F_g = (rope_mass/node_num) * gravity
                F_net = F_top + F_below + F_g
                
                forces.append(F_net)
        for i in range(len(massList)):
            m = massList[i]
            m.vel += forces[i] / node_mass * dt
    
        for i in range(len(massList)):
            m = massList[i]
            m.pos += m.vel * dt
        if len(massList) > 0:
            last_mass = massList[-1]
            r = cow.pos - last_mass.pos
            F_spring = -k_each * (mag(r) - spring_length/node_num) * norm(r)
            F_g = cow_mass * gravity
            
            cow.acc = (F_spring + F_g) / cow_mass
            cow.vel += cow.acc * dt
            cow.pos += cow.vel * dt
        else: 
            r = cow.pos-spring0.pos
            r_hat = norm(r)
            current_length = mag(r)
            elongation = current_length - spring_length  
            spring_force = - k_each * elongation * r_hat
            gravitational_force = cow_mass * gravity   
            F_net = gravitational_force + spring_force
            cow.acc = F_net / cow_mass
            cow.vel+= cow.acc * dt
            cow.pos+= cow.vel * dt
            spring0.axis = cow.pos - spring0.pos
        
        
        height = init_cowpos.y - cow.pos.y
        t+=dt
        kinenergy = (0.5)*cow_mass*(cow.vel).mag**2
        elasticenergy = (0.5) * k_rope * elongation ** 2
        ugenergy = cow_mass * height * gravity 
        ug_curve.plot(t, ugenergy.y)
        ke_curve.plot(t, kinenergy)
        ue_curve.plot(t, elasticenergy)
        phase_curve.plot(cow.pos.x, cow.vel.x)


    
    
    
    

