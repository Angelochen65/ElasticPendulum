scene.background = vector(0.69, 0.859, 1)
water = box(pos=vector(0, -5, 0), size=vec(100, 10, 100), texture = "https://static.vecteezy.com/system/resources/previews/042/657/776/non_2x/water-texture-seamless-repeat-pattern-with-tranquil-turquoise-ripples-vector.jpg", opacity = 0.5)
