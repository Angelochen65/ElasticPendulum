node_num = 1 #total number of nodes VARIABLE; 1 is default, with spring and cow 
spring_num = node_num 
rope_length = 1 #VARIABLE
rope_mass = 5 #VARIABLE 

#The following variables are calculated based on the sliders 
k_each = k_rope / spring_num #CALCULATED 
spring_length = rope_length / spring_num #CALCULATED 
gravity = vector(0,-9.81,0)
node_mass = rope_mass / node_num #CALCULATED 


attatchment_point = box(pos=vector(0, 5, 0), size=vector(2, 0.1, 0.1), color=color.gray(1))
spring0 = helix(pos=vector(0,5,0), axis=vector(0,-1,0), size=vector(5,1,1), stiffness=1.0 )
cow = sphere(pos=spring0.pos+spring0.axis, radius=0.1, color=color.white)


