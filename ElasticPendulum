def change_angle_long(ang):
    spring_length=rope_length_slider.value
    spring0.axis.y = spring_length*cos(ang.value)
    spring0.axis.x = -spring_length*sin(ang.value)
    cow.pos = spring0.pos + spring0.axis
    global axis
    axis = spring0.axis
    LongAngleText.text = '{:1.2f}'.format(degrees(ang.value))
    
def change_angle_zaxis(ang):
    spring_length=rope_length_slider.value
    spring0.axis.z = -spring_length*sin(ang.value)
    cow.pos = spring0.pos + spring0.axis
    global axis
    axis = spring0.axis
    ZAngleText.text = '{:1.2f}'.format(degrees(ang.value))
    
    

scene.append_to_caption("XY Spring Angle\n\n")
angle_slider_long = slider(bind=change_angle_long, min=pi/2, max=3*pi/2, step=pi/30, value=init_longangle)
LongAngleText = wtext(text='{:1.2f} degrees'.format(angle_slider_long.value))
scene.append_to_caption('\n\n')
scene.append_to_caption("Z Spring Angle\n\n")
angle_slider_zaxis = slider(bind=change_angle_zaxis, min=-pi/2, max=pi/2, step=pi/30, value=init_zangle)
ZAngleText = wtext(text='{:1.2f} degrees'.format(angle_slider_zaxis.value))

t = 0
dt = 0.001
mass_init_v = 0
cow.vel = vector(0,0,0)
cow.acc = vector(0,0,0)
elongation = 0

running = False

startButton = button(bind=bouncing, text="Click to start", background=color.red, pos=scene.title_anchor)
resetButon = button(bind=reset, text = "Reset", background = color.blue, pos = scene.title_anchor)

#Setting up graphs
ke_graph = graph(title="Kinetic Energy vs. Time", xtitle="Time (s)", ytitle="Kinetic Energy (J)", align = "left")
ke_curve = gcurve(color=color.blue, label = "Kinetic Energy")
ue_graph = graph(title="Elastic Potential Energy vs. Time", xtitle="Time (s)", ytitle="Elastic Potential Energy (J)", align = "left")
ue_curve = gcurve(color=color.red, label = "Elastic Potential Energy")
ug_graph = graph(title="Gravitational Potential Energy vs. Time", xtitle="Time (s)", ytitle="Gravitational Potential Energy (J)", align = "left")
ug_curve = gcurve(color=color.green, label = "Gravitational Potential Energy")
phase_graph = graph(title="Phase Graph", xtitle="Cow Position", ytitle="Cow Velocity", align = "left")
phase_curve = gcurve(color=color.orange, label = "Phase Graph")

ugenergy = 0

def reset():
    global running
    startButton.text = "Click to Start"
    running = False
    spring0.pos = vector(0,5,0)
    spring0.axis = vector(0,-1,0)
    cow.pos = spring0.pos + spring0.axis
    t = 0
    dt = 0.001
    mass_init_v = 0
    cow.vel = vector(0,0,0)
    cow.acc = vector(0,0,0)
    elongation = 0
    angle_slider_long.value = init_longangle
    angle_slider_zaxis.value = init_zangle
    rope_length_slider.value = spring_length
    cow_mass_slider.value = cow_mass
    scene.camera.pos = vec(0,5,5)
    wt.text=rope_length
    
    
   

def bouncing():
    global running
    
    running = not running

while True:  
    rate(1/dt)
    if not running: 
        startButton.text = "Start"
        if(node_num > 1 and addSpring):
            for s in springList:
                s.visible = False
            springList = []
            eachAxis = vector(0, - rope_length / node_num, 0)
            currentPos = springPos
            for i in range(node_num):
                
                newSpring = helix(pos = currentPos, axis = eachAxis, size=vector(spring_length / node_num,1,1), stiffness = 1)
                springList.append(newSpring)
                currentPos+= eachAxis
            cow.pos = springList[-1].pos + springList[-1].axis
            spring0 = springList[0]
            addSpring = not addSpring

    if running:  
        startButton.text = "Stop"
        r = cow.pos-spring0.pos
        r_hat = norm(r)
        current_length = mag(r)
        elongation = current_length - spring_length  
        spring_force = - k_each * elongation * r_hat
        gravitational_force = cow_mass * gravity   
        f_net = gravitational_force + spring_force
        cow.acc = f_net / cow_mass
        cow.vel+= cow.acc * dt
        cow.pos+= cow.vel * dt
        spring0.axis = cow.pos - spring0.pos

        height = init_cowpos.y - cow.pos.y
        t= t + dt
        kinenergy = (0.5)*cow_mass*(cow.vel).mag**2
        elasticenergy = (0.5) * k_rope * elongation ** 2
        ugenergy = gravitational_force * height

        ug_curve.plot(t, ugenergy.y)
        ke_curve.plot(t, kinenergy)
        ue_curve.plot(t, elasticenergy)
        phase_curve.plot(cow.pos.x, cow.vel.x)
    
    
    

