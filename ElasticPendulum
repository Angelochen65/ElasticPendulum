#Cow kinematics variables
equilPos = (0,0,0)
initPos = vector(0,0,0)
initVel = vector(0,0,0)


attatchment_point = box(pos=vector(0, 5, 0), size=vector(2, 0.1, 0.1), color=color.gray(1))
spring0 = helix(pos=vector(0,5,0), axis=vector(0,-1,0), size=vector(5,1,1), stiffness=1.0 )
cow = sphere(pos=vec(0, 0, 0), radius=0.1, color=color.white)

springList = []
springList.append(spring0)

def change_length(l):
    rope_length = l.value
    spring_length = rope_length / spring_num #CALCULATED 
    for i in range(len(springList)):
        springList[i].length = spring_length

def change_length(l):
    rope_length = l.value
    spring_length = rope_length / spring_num #CALCULATED 
    for i in range(len(springList)):
        springList[i].length = spring_length

rope_length_slider = slider(bind=change_length, min=1, max=10, step=0.1, value=5)

   
def change_cow_mass(num):
    cow.radius=num.value

cow_mass_slider = slider(bind=change_cow_mass, min=0.1, max=1.5, step=0.01, value=0.1)

def change_angle_long(ang):
    spring_length=rope_length_slider.value
    spring0.axis.y = spring_length*cos(ang.value)
    spring0.axis.x = -spring_length*sin(ang.value)
    
def change_angle_zaxis(ang):
    #spring_length=rope_length_slider.value
    spring0.axis.z = -spring_length*sin(ang.value)
    
    
    
angle_slider_long = slider(bind=change_angle_long, min=pi/2, max=3*pi/2, step=pi/30, value=pi)
scene.append_to_caption('\n\n')
angle_slider_zaxis = slider(bind=change_angle_zaxis, min=-pi/2, max=pi/2, step=pi/30, value=0)

